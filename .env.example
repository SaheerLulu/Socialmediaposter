# ── PostPilot configuration ───────────────────────────────────────────────
# Copy to `.env` and fill in. Everything works in DRY_RUN with no keys.

# --- Core -------------------------------------------------------------------
# Any model string init_chat_model understands (provider inferred or prefixed).
SOCIAL_POSTER_MODEL=claude-sonnet-4-5-20250929
# Provider key for the default Claude model:
ANTHROPIC_API_KEY=

# true  -> simulate posting, write to ./outbox, no credentials needed (default)
# false -> publish for real (requires the platform credentials below)
SOCIAL_POSTER_DRY_RUN=true

# Image backend: auto | openai | gemini | placeholder
SOCIAL_POSTER_IMAGE_PROVIDER=auto

# --- Image generation (optional) -------------------------------------------
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Twitter / X (only when DRY_RUN=false) ---------------------------------
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# --- Instagram Graph API (only when DRY_RUN=false) -------------------------
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- LinkedIn (only when DRY_RUN=false) ------------------------------------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:XXXXXXXX

# ── DealDesk: sales & marketing module ─────────────────────────────────────
# true -> simulate outreach to ./outbox/marketing (default, no credentials)
MARKETING_DRY_RUN=true
# Only contact leads with a lawful basis (opt-in / legitimate interest).
# Keep true unless you have verified lawful basis for every contact.
MARKETING_REQUIRE_OPT_IN=true
# false -> drafts wait for human approval; true -> daemon auto-sends (careful!)
MARKETING_AUTONOMOUS=false
MARKETING_UNSUBSCRIBE_URL=https://example.com/unsubscribe

# Throttling & cadence
MARKETING_MAX_PER_RUN=25
MARKETING_MAX_PER_DAY=200
MARKETING_MIN_SECONDS_BETWEEN_SENDS=3
MARKETING_QUIET_START=21          # local hour to stop outreach
MARKETING_QUIET_END=8             # local hour to resume outreach
MARKETING_FOLLOWUP_DAYS=3
MARKETING_MAX_TOUCHES=3
MARKETING_RUN_INTERVAL_SECONDS=3600   # daemon batch cadence

# Business profile the agent reasons about (yaml or json)
MARKETING_BUSINESS_PROFILE=data/business_profile.yaml

# CRM database backend: "sql" (Postgres/SQLAlchemy) or "json" (file).
# Defaults to sql when DATABASE_URL is set, else json.
MARKETING_DB_BACKEND=sql
# Postgres connection (leave blank to fall back to a local SQLite file).
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/crm

# Email outreach (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# WhatsApp outreach: provider = meta | twilio
WHATSAPP_PROVIDER=meta
# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
# Twilio (if WHATSAPP_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886
